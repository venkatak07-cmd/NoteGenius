{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":15214540,"datasetId":9733240,"databundleVersionId":16109550}],"dockerImageVersionId":31287,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# I got tired of ctrl+F-ing through 500-page PDFs during exam week.\n# So I spent a weekend building this — NoteGenius.\n# Ask it anything. It finds the answer in your own notes.\n#\n# Stack I ended up going with:\n#   - pypdf to rip text out of the PDFs\n#   - TF-IDF + cosine similarity for retrieval (no vector DB needed, honestly)\n#   - Mistral-7B-Instruct running in 4-bit on Kaggle's free T4 GPU\n#   - Gradio for the UI so I could share it with friends easily\n#\n# If you're reading this — run all cells top to bottom.\n# Takes about 8-10 mins first time (model download). Worth it.\n \n \n# ── Cell 1: Install everything we need ────────────────────────────────────────\n#\n# Nothing exotic here. bitsandbytes is the one that does the 4-bit magic.\n# accelerate handles the device mapping so we don't have to think about it.\n \nimport os\nos.environ[\"PIP_ROOT_USER_ACTION\"] = \"ignore\"\n \n!pip install -q --no-cache-dir \\\n    pypdf        \\\n    scikit-learn \\\n    transformers \\\n    accelerate   \\\n    bitsandbytes \\\n    gradio       \\\n    pandas       \\\n    matplotlib\n \nprint(\"all good, packages installed.\")\n ","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-16T17:16:29.507303Z","iopub.execute_input":"2026-03-16T17:16:29.507942Z","iopub.status.idle":"2026-03-16T17:16:33.301953Z","shell.execute_reply.started":"2026-03-16T17:16:29.507918Z","shell.execute_reply":"2026-03-16T17:16:33.300997Z"}},"outputs":[{"name":"stdout","text":"all good, packages installed.\n","output_type":"stream"}],"execution_count":1},{"cell_type":"code","source":"# ── Cell 2: Find the PDFs ──────────────────────────────────────────────────────\n#\n# Point PDF_DIR at whatever Kaggle dataset folder has your PDFs.\n# I'm using my own GenAI notes dataset — swap it out for yours.\n# The rglob(\"*.pdf\") means it'll find PDFs in subdirectories too, which is handy.\n \nfrom pathlib import Path\n \nPDF_DIR  = Path(\"/kaggle/input/datasets/sanjeevkv007/genainotes\")\nWORK_DIR = Path(\"/kaggle/working/notegeniusai\")\nWORK_DIR.mkdir(parents=True, exist_ok=True)\n \nif not PDF_DIR.exists():\n    raise FileNotFoundError(f\"can't find the folder: {PDF_DIR}\")\n \npdfs = sorted(PDF_DIR.rglob(\"*.pdf\"))\nif not pdfs:\n    raise FileNotFoundError(f\"no PDFs in there: {PDF_DIR}\")\n \nprint(f\"found {len(pdfs)} PDF(s):\\n\")\nfor i, p in enumerate(pdfs, 1):\n    kb = p.stat().st_size / 1024\n    print(f\"  {i}. {p.name}  ({kb:.0f} KB)\")\n \n \n# ── Cell 3: Parse PDFs → chunk text → build TF-IDF index ──────────────────────\n#\n# The chunking overlap (200 chars) matters more than people think.\n# Without it you get hard cuts mid-sentence and the retrieval quality tanks.\n# 1200 chars per chunk is a sweet spot — enough context, not too noisy.\n#\n# I went with TF-IDF instead of embeddings because:\n#   a) it's fast and has zero GPU requirements\n#   b) for keyword-heavy technical notes it actually performs really well\n#   c) no need to spin up a separate embedding model\n \nimport re\nimport pickle\nfrom pypdf import PdfReader\nfrom sklearn.feature_extraction.text import TfidfVectorizer\n \n \ndef clean_text(x):\n    # pypdf sometimes gives back weird null bytes and BOM characters\n    # this just strips all of that out and collapses whitespace\n    if x is None:\n        return \"\"\n    try:\n        x = str(x)\n    except Exception:\n        return \"\"\n    x = x.replace(\"\\x00\", \" \").replace(\"\\ufeff\", \" \")\n    return re.sub(r\"\\s+\", \" \", x).strip()\n \n \ndef chunk_text(text, chunk_size=1200, overlap=200):\n    # sliding window chunker — overlap keeps context from bleeding across chunk edges\n    text = clean_text(text)\n    if len(text) < 30:\n        return []\n \n    chunks, start, n = [], 0, len(text)\n    while start < n:\n        end   = min(start + chunk_size, n)\n        chunk = clean_text(text[start:end])\n        if len(chunk) >= 50:\n            chunks.append(chunk)\n        if end >= n:\n            break\n        start = max(end - overlap, start + 1)\n    return chunks\n \n \ndocuments = []\n \nprint(\"reading PDFs...\\n\")\nfor pdf_path in pdfs:\n    reader  = PdfReader(str(pdf_path))\n    before  = len(documents)\n \n    for page_idx, page in enumerate(reader.pages):\n        try:\n            raw = page.extract_text() or \"\"\n        except Exception:\n            raw = \"\"\n \n        page_text = clean_text(raw)\n        if len(page_text) < 30:\n            continue\n \n        for chunk in chunk_text(page_text, chunk_size=1200, overlap=200):\n            documents.append({\n                \"text\":        chunk,\n                \"source_name\": pdf_path.name,\n                \"source_file\": str(pdf_path),\n                \"page\":        page_idx + 1,\n            })\n \n    print(f\"  {pdf_path.name}  →  {len(documents) - before} chunks\")\n \nif not documents:\n    raise ValueError(\"nothing came out of the PDFs — check if they're scanned images\")\n \ntexts = [d[\"text\"] for d in documents]\nprint(f\"\\ntotal chunks: {len(texts)}\")\nprint(f\"first chunk preview:\\n  {repr(texts[0][:200])}\\n\")\n \n# building the index — bigrams help a lot for technical terms like \"gradient descent\"\nprint(\"building TF-IDF index...\")\nvectorizer = TfidfVectorizer(\n    stop_words=\"english\",\n    ngram_range=(1, 2),\n    max_features=50_000,\n)\ndoc_matrix = vectorizer.fit_transform(texts)\n \n# save to disk so we can reload later without re-parsing\nwith open(WORK_DIR / \"documents.pkl\",  \"wb\") as f: pickle.dump(documents,  f)\nwith open(WORK_DIR / \"vectorizer.pkl\", \"wb\") as f: pickle.dump(vectorizer, f)\n \nprint(f\"done. matrix is {doc_matrix.shape[0]} chunks × {doc_matrix.shape[1]} features\")\n ","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-16T17:16:42.831162Z","iopub.execute_input":"2026-03-16T17:16:42.831900Z","iopub.status.idle":"2026-03-16T17:19:41.303343Z","shell.execute_reply.started":"2026-03-16T17:16:42.831865Z","shell.execute_reply":"2026-03-16T17:19:41.302406Z"}},"outputs":[{"name":"stdout","text":"found 44 PDF(s):\n\n  1. BOOK-Generative-AI-CPP-Spuler-2024.pdf  (3834 KB)\n  2. CUDA-CPP-Debugginb-Book-Spuler-2024.pdf  (1288 KB)\n  3. CUDA-CPP-Optimization-Book-Spuler-2024.pdf  (1300 KB)\n  4. DS_merged_notes.pdf  (2366 KB)\n  5. Data Science.pdf  (21798 KB)\n  6. GenAI_Latest_notes.pdf  (1709 KB)\n  7. Generative-AI-Applications-Spuler-Sharpe-2024.pdf  (1931 KB)\n  8. Interview preparation - Day10.pdf  (958 KB)\n  9. Interview preparation - Day11.pdf  (403 KB)\n  10. Interview preparation - Day12.pdf  (669 KB)\n  11. Interview preparation - Day13.pdf  (306 KB)\n  12. Interview preparation - Day14.pdf  (722 KB)\n  13. Interview preparation - Day15.pdf  (595 KB)\n  14. Interview preparation - Day16.pdf  (814 KB)\n  15. Interview preparation - Day17.pdf  (959 KB)\n  16. Interview preparation - Day6.pdf  (946 KB)\n  17. Interview preparation - Day7.pdf  (1559 KB)\n  18. Interview preparation - Day8.pdf  (752 KB)\n  19. Interview preparation - Day9.pdf  (1179 KB)\n  20. Machine Learning with python.pdf  (30806 KB)\n  21. Python 3 For Absolute Beginners.pdf  (1552 KB)\n  22. Python Textbook.pdf  (1582 KB)\n  23. RAG-Optimization-Spuler-Sharpe-2025.pdf  (2039 KB)\n  24. SQL.pdf  (1181 KB)\n  25. Statistics - Andrew Siegel.pdf  (15809 KB)\n